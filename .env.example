# Base de datos
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=proyecto_taller
DB_PORT=5432

# Backend
PORT=3000
NODE_ENV=production
SWAGGER_ENABLED=false
ALLOWED_ORIGIN=https://compex.bitwaise.com,https://me-compex.bitwaise.com

# JWT
JWT_ACCESS_SECRET=changeme_access_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=changeme_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

# IA
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# IA OpenAI-compatible opcional
OPENAI_COMPATIBLE_BASE_URL=http://localhost:1234/v1
OPENAI_COMPATIBLE_API_KEY=local
OPENAI_COMPATIBLE_MODEL=google/gemma-4-12b-qat

# Frontend
API_URL=https://api-compex.bitwaise.com/api

# Nginx
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
