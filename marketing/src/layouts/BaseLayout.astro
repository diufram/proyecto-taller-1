---
import { t, type Locale } from '../i18n/utils';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import SeoHead from '../components/SeoHead.astro';
import '../styles/global.css';

const pathLocale = Astro.url.pathname.split('/')[1];
const locale: Locale = pathLocale === 'en' ? 'en' : 'es';

const title = t(locale, 'brand.name');
const description = t(locale, 'brand.tagline');
---

<!doctype html>
<html lang={locale}>
    <head>
        <SeoHead locale={locale} title={title} description={description} />
    </head>
    <body>
        <Navbar locale={locale} />
        <main>
            <slot />
        </main>
        <Footer locale={locale} />
    </body>
</html>