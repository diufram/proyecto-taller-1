---
import { t, type Locale } from '../i18n/utils';

interface Props {
    locale: Locale;
}

const { locale } = Astro.props;

const tiers = [
    {
        key: 'free' as const,
        priceKey: 'pricing.tiers.free.price' as const,
        periodKey: 'pricing.tiers.free.period' as const,
        ctaKey: 'pricing.tiers.free.cta' as const,
        href: 'https://app.compex.example.com/auth/register?plan=free',
        highlighted: false,
    },
    {
        key: 'pro' as const,
        priceKey: 'pricing.tiers.pro.price' as const,
        periodKey: 'pricing.tiers.pro.period' as const,
        ctaKey: 'pricing.tiers.pro.cta' as const,
        href: 'https://app.compex.example.com/auth/register?plan=pro',
        highlighted: true,
    },
    {
        key: 'enterprise' as const,
        priceKey: 'pricing.tiers.enterprise.price' as const,
        periodKey: 'pricing.tiers.enterprise.period' as const,
        ctaKey: 'pricing.tiers.enterprise.cta' as const,
        href: 'mailto:ventas@compex.example.com',
        highlighted: false,
    },
];
---

<div class="pricing-grid">
    {
        tiers.map((tier) => {
            const features = t(locale, `pricing.tiers.${tier.key}.features` as any)
                .split('|')
                .map((f) => f.trim())
                .filter(Boolean);

            return (
                <article class:list={['tier', tier.highlighted && 'is-highlighted']}>
                    {tier.highlighted && (
                        <span class="tier-badge">{t(locale, 'pricing.tiers.pro.popular')}</span>
                    )}
                    <h3 class="tier-name">{t(locale, `pricing.tiers.${tier.key}.name` as any)}</h3>
                    <p class="tier-tagline">{t(locale, `pricing.tiers.${tier.key}.tagline` as any)}</p>

                    <div class="tier-price">
                        <span class="tier-amount">{t(locale, tier.priceKey)}</span>
                        <span class="tier-period">{t(locale, tier.periodKey)}</span>
                    </div>

                    {tier.key === 'pro' && (
                        <p class="tier-yearly">
                            {t(locale, 'pricing.tiers.pro.priceYear')} ·{' '}
                            {t(locale, 'pricing.tiers.pro.periodYear')}
                        </p>
                    )}

                    <ul class="tier-features">
                        {features.map((f) => (
                            <li>
                                <i class="pi pi-check" aria-hidden="true"></i>
                                <span>{f}</span>
                            </li>
                        ))}
                    </ul>

                    <a
                        href={tier.href}
                        class:list={['btn', tier.highlighted ? 'btn-primary' : 'btn-ghost', 'tier-cta']}
                    >
                        {t(locale, tier.ctaKey)}
                    </a>
                </article>
            );
        })
    }
</div>

<style>
    .pricing-grid {
        display: grid;
        gap: 1.25rem;
        grid-template-columns: 1fr;
    }

    @media (min-width: 720px) {
        .pricing-grid {
            grid-template-columns: repeat(3, minmax(0, 1fr));
            align-items: stretch;
        }
    }

    .tier {
        position: relative;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: clamp(1.5rem, 3vw, 2.25rem) clamp(1.25rem, 2.5vw, 2rem);
        display: flex;
        flex-direction: column;
        gap: 0.85rem;
        transition: transform 0.15s ease, border-color 0.15s ease,
            box-shadow 0.15s ease;
    }

    .tier:hover {
        transform: translateY(-2px);
        border-color: rgba(52, 211, 153, 0.35);
    }

    .tier.is-highlighted {
        background:
            radial-gradient(circle at top, rgba(52, 211, 153, 0.16), transparent 60%),
            var(--surface);
        border-color: rgba(52, 211, 153, 0.45);
        box-shadow: 0 18px 40px rgba(16, 185, 129, 0.18);
    }

    .tier-badge {
        position: absolute;
        top: -0.7rem;
        left: 50%;
        transform: translateX(-50%);
        background: linear-gradient(135deg, #34d399, #10b981);
        color: #0a0a0f;
        font-size: 0.7rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        padding: 0.25rem 0.7rem;
        border-radius: 999px;
        box-shadow: 0 6px 16px rgba(16, 185, 129, 0.35);
    }

    .tier-name {
        margin: 0;
        font-size: 1.15rem;
        color: var(--text);
    }

    .tier-tagline {
        margin: 0;
        font-size: 0.85rem;
        color: var(--text-muted);
    }

    .tier-price {
        display: flex;
        align-items: baseline;
        gap: 0.4rem;
        margin-top: 0.5rem;
    }

    .tier-amount {
        font-size: 2.4rem;
        font-weight: 800;
        letter-spacing: -0.02em;
        color: var(--text);
    }

    .tier-period {
        font-size: 0.85rem;
        color: var(--text-muted);
    }

    .tier-yearly {
        margin: 0;
        font-size: 0.82rem;
        color: var(--accent);
        font-weight: 600;
    }

    .tier-features {
        list-style: none;
        margin: 0.75rem 0 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        flex: 1;
    }

    .tier-features li {
        display: flex;
        align-items: flex-start;
        gap: 0.55rem;
        font-size: 0.92rem;
        color: var(--text-muted);
    }

    .tier-features li i {
        color: var(--accent);
        margin-top: 0.18rem;
        flex: 0 0 auto;
    }

    .tier-features li span {
        color: var(--text);
        line-height: 1.45;
    }

    .tier-cta {
        margin-top: 1rem;
        justify-content: center;
        width: 100%;
    }
</style>