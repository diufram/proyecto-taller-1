# Servicio AI (solo LM Studio local)
AI_SERVICE_HOST=0.0.0.0
AI_SERVICE_PORT=8000
AI_SERVICE_LOG_LEVEL=info

# LM Studio (OpenAI-compatible)
# En dev local con uvicorn directo: http://localhost:1234/v1
# En dev local con docker run:    http://host.docker.internal:1234/v1
# En deploy remoto:                http://<ip-vps-lmstudio>:1234/v1
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_API_KEY=lm-studio
LMSTUDIO_MODEL=qwen2.5-coder-7b-instruct
LMSTUDIO_TIMEOUT_SECONDS=120

# Persistencia local (runs JSONL y registry JSON)
AI_SERVICE_DATA_DIR=./data
